<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
    <key id="d0" for="node" attr.name="index" attr.type="int"/>
    <key id="d0x" for="node" attr.name="posX" attr.type="double"/>
    <key id="d0y" for="node" attr.name="posY" attr.type="double"/>
    <key id="d1" for="node" attr.name="module" attr.type="int"/>
    <key id="d1b" for="node" attr.name="bestmodule" attr.type="int"/>
    <key id="d2" for="edge" attr.name="weight" attr.type="int"/>
    <graph id="G" edgedefault="undirected">
        <node id="n0">
            <data key="d0">0</data>
            <data key="d1">0</data>
            <data key="d1b">0</data>
            <data key="d0x">101</data>
            <data key="d0y">42</data>
        </node>
        <node id="n1">
            <data key="d0">1</data>
            <data key="d1">1</data>
            <data key="d1b">0</data>
            <data key="d0x">230</data>
            <data key="d0y">11</data>
        </node>
        <node id="n2">
            <data key="d0">2</data>
            <data key="d1">2</data>
            <data key="d1b">0</data>
            <data key="d0x">296</data>
            <data key="d0y">106</data>
        </node>
        <node id="n3">
