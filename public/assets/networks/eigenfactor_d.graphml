            <data key="d1">4</data>
            <data key="d1b">0</data>
            <data key="d0x">218</data>
            <data key="d0y">324</data>
        </node>
        <node id="n5">
            <data key="d0">5</data>
            <data key="d1">5</data>
            <data key="d1b">0</data>
            <data key="d0x">101</data>
            <data key="d0y">392</data>
        </node>
		<edge id="e0" source="n0" target="n1">
            <data key="d2">1</data>
        </edge>
        <edge id="e1" source="n1" target="n0">
            <data key="d2">1</data>
        </edge>
        <edge id="e2" source="n1" target="n2">
            <data key="d2">1</data>
        </edge>
        <edge id="e3" source="n2" target="n0">
            <data key="d2">1</data>
        </edge>
        <edge id="e4" source="n2" target="n3">
            <data key="d2">1</data>
        </edge>
        <edge id="e5" source="n3" target="n0">
            <data key="d2">1</data>
        </edge>
        <edge id="e6" source="n3" target="n4">
            <data key="d2">1</data>
        </edge>
        <edge id="e7" source="n4" target="n0">
            <data key="d2">1</data>
        </edge>
        <edge id="e8" source="n4" target="n5">
            <data key="d2">1</data>
        </edge>
        <edge id="e9" source="n5" target="n0">
            <data key="d2">1</data>
        </edge>
    </graph>
</graphml>
